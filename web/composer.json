{
  "name": "heatforge/web",
  "description": "HeatForge — продажа мангалов. PHP+Twig SSR",
  "type": "project",
  "require": {
    "php": ">=8.1",
    "twig/twig": "^3.0"
  },
  "autoload": {
    "psr-4": {
      "Heatforge\\": "src/php/"
    }
  },
  "config": {
    "optimize-autoloader": true,
    "preferred-install": "dist"
  }
}
